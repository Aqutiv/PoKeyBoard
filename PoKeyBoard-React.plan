    TransportControls.tsx
    MetronomeControls.tsx
    ExportDialog.tsx
    LoadingOverlay.tsx
  features/
    keyboard/
      PianoKeyboard.tsx
      PianoKey.tsx
      keyboardGeometry.ts
      touchNoteTracker.ts
    notation/
      MusicScore.tsx
      notationLayout.ts
      notationTypes.ts
      quantization.ts
      staffMapping.ts
      scrubController.ts
    takes/
      TakeList.tsx
      TakeListItem.tsx
      TakeEditorHeader.tsx
  data/
    database.ts
